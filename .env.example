# Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sadece sunucuda (Vercel'de Environment Variables). İstemciye koyma.
SUPABASE_SERVICE_ROLE_KEY=

# ID + sifre giris (e-posta yok)
